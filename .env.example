# Required: AI
GEMINI_API_KEY=
GEMINI_MODEL=gemini-3.5-flash

# Required for persistence: Supabase
NEXT_PUBLIC_SUPABASE_URL=
NEXT_PUBLIC_SUPABASE_ANON_KEY=
SUPABASE_SERVICE_ROLE_KEY=
SUPABASE_BUCKET=inspection-images

# Optional: Auth (required for production)
AUTH_SECRET=
AUTH_URL=http://localhost:3000

# Optional: Rate limiting (Vercel KV / Upstash Redis)
KV_URL=
KV_REST_API_URL=
KV_REST_API_TOKEN=
# Set to 1 to disable rate limiting entirely (escape hatch for self-hosted
# deployments without KV — otherwise /api/analyze fails closed in production)
RATE_LIMIT_DISABLED=

# Optional: Signed URLs for private storage
SUPABASE_SIGNED_URLS=false

# Required: App URL
NEXT_PUBLIC_APP_URL=http://localhost:3000
NEXT_PUBLIC_SITE_NAME=BuildScan AI

# Optional: Monitoring
NEXT_PUBLIC_SENTRY_DSN=
SENTRY_AUTH_TOKEN=

# Optional: Logging
LOG_LEVEL=info

# Optional: Detection service (Python YOLO + Depth Anything V2)
DETECTION_SERVICE_URL=http://localhost:8000
YOLO_MODEL_PATH=OpenSistemas/YOLOv8-crack-seg/yolov8s/weights/best.pt